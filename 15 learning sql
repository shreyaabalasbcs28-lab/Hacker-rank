SELECT 
    s1.submission_date,
    (SELECT COUNT(DISTINCT s2.hacker_id)
     FROM Submissions s2
     WHERE s2.submission_date = s1.submission_date
       AND (SELECT COUNT(DISTINCT s3.submission_date)
            FROM Submissions s3
            WHERE s3.hacker_id = s2.hacker_id
              AND s3.submission_date < s1.submission_date) = (DAYS(s1.submission_date) - DAYS('2016-03-01'))),
    (SELECT s4.hacker_id
     FROM Submissions s4
     WHERE s4.submission_date = s1.submission_date
     GROUP BY s4.hacker_id
     ORDER BY COUNT(s4.submission_id) DESC, s4.hacker_id ASC
     FETCH FIRST 1 ROW ONLY) AS top_hacker,
    (SELECT h.name 
     FROM Hackers h 
     WHERE h.hacker_id = (SELECT s4.hacker_id
                          FROM Submissions s4
                          WHERE s4.submission_date = s1.submission_date
                          GROUP BY s4.hacker_id
                          ORDER BY COUNT(s4.submission_id) DESC, s4.hacker_id ASC
                          FETCH FIRST 1 ROW ONLY))
FROM (SELECT DISTINCT submission_date FROM Submissions) s1
ORDER BY s1.submission_date;
