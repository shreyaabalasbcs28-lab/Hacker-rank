SELECT 
    VALUE(MAX(CASE WHEN OCCUPATION = 'Doctor' THEN NAME END), 'NULL'),
    VALUE(MAX(CASE WHEN OCCUPATION = 'Professor' THEN NAME END), 'NULL'),
    VALUE(MAX(CASE WHEN OCCUPATION = 'Singer' THEN NAME END), 'NULL'),
    VALUE(MAX(CASE WHEN OCCUPATION = 'Actor' THEN NAME END), 'NULL')
FROM (
    SELECT 
        NAME, 
        OCCUPATION, 
        ROW_NUMBER() OVER (PARTITION BY OCCUPATION ORDER BY NAME) AS RN
    FROM OCCUPATIONS
) AS TEMP
GROUP BY RN
ORDER BY RN;
