SELECT 
    con."CONTEST_ID", 
    con."HACKER_ID", 
    con."NAME", 
    SUM(sg.ts), 
    SUM(sg.tas), 
    SUM(vg.tv), 
    SUM(vg.tuv)
FROM "CONTESTS" con
JOIN "COLLEGES" col ON con."CONTEST_ID" = col."CONTEST_ID"
JOIN "CHALLENGES" cha ON col."COLLEGE_ID" = cha."COLLEGE_ID"
LEFT JOIN (
    SELECT "CHALLENGE_ID", 
           SUM("TOTAL_SUBMISSIONS") AS ts, 
           SUM("TOTAL_ACCEPTED_SUBMISSIONS") AS tas
    FROM "SUBMISSION_STATS" 
    GROUP BY "CHALLENGE_ID"
) sg ON cha."CHALLENGE_ID" = sg."CHALLENGE_ID"
LEFT JOIN (
    SELECT "CHALLENGE_ID", 
           SUM("TOTAL_VIEWS") AS tv, 
           SUM("TOTAL_UNIQUE_VIEWS") AS tuv
    FROM "VIEW_STATS" 
    GROUP BY "CHALLENGE_ID"
) vg ON cha."CHALLENGE_ID" = vg."CHALLENGE_ID"
GROUP BY con."CONTEST_ID", con."HACKER_ID", con."NAME"
HAVING (SUM(sg.ts) + SUM(sg.tas) + SUM(vg.tv) + SUM(vg.tuv)) > 0
ORDER BY con."CONTEST_ID";
